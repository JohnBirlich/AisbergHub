-- Aisberg Hub | +1 Aura Speed Escape
-- Auto TP loop start <-> end + anti-popups

local Players = game:GetService("Players")
local UIS     = game:GetService("UserInputService")
local RS      = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

print("[AisbergHub] Aura TP script loaded")

--------------------------------------------------
-- Точки
--------------------------------------------------

local START_CF = CFrame.new(
    -592.599365, 36.1112404, 2004.25488,
    1, 0, 0,
    0, 1, 0,
    0, 0, 1
)

local END_CF = CFrame.new(
    -565.550415, 24.2728081, -6068.28613,
    -1, 0, 0,
    0, 1, 0,
    0, 0, -1
)

local running = false

local function getRoot()
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:FindFirstChild("HumanoidRootPart")
        or char:FindFirstChild("LowerTorso")
        or char:FindFirstChildWhichIsA("BasePart")
    return root
end

local function tpDirect(cf)
    local root = getRoot()
    if not root then
        warn("[AisbergHub] No root part")
        return
    end
    root.CFrame = cf
end

--------------------------------------------------
-- Луп авто-ТП
--------------------------------------------------

local function startLoop()
    if running then return end
    running = true
    print("[AisbergHub] Auto TP loop START")

    task.spawn(function()
        while running do
            tpDirect(START_CF)
            task.wait(0.1)
            tpDirect(END_CF)

            -- пауза ~1 сек (разбита, чтобы можно было остановить)
            for i = 1, 10 do
                if not running then break end
                task.wait(0.1)
            end
        end

        print("[AisbergHub] Auto TP loop STOP")
    end)
end

local function stopLoop()
    running = false
end

--------------------------------------------------
-- GUI всегда поверх
--------------------------------------------------

local gui = Instance.new("ScreenGui")
gui.Name = "AisbergHub_AutoTP"
gui.ResetOnSpawn = false
