--------------------------------------------------
-- Hook RemoteEvent PopUp / WinPopUp (глушим FireServer с клиента)
--------------------------------------------------

local net = RS:FindFirstChild("Network")
local guiNet = net and net:FindFirstChild("Gui")

if guiNet and guiNet:FindFirstChild("Notifications") then
    local notif = guiNet.Notifications
    local popUp = notif:FindFirstChild("PopUp")
    local winPopUp = notif:FindFirstChild("WinPopUp")

    if popUp or winPopUp then
        local mt = getrawmetatable(game)
        local oldReadOnly = isreadonly and isreadonly(mt)
        setreadonly(mt, false)
        local oldNamecall = mt.__namecall

        mt.__namecall = function(self, ...)
            local method = getnamecallmethod()
            if method == "FireServer" and (self == popUp or self == winPopUp) then
                -- не отправляем запросы на показ попапов
                return
            end
            return oldNamecall(self, ...)
        end

        if oldReadOnly ~= false then
            setreadonly(mt, true)
        end

        print("[AisbergHub] PopUp/WinPopUp FireServer hooked")
    end
end

--------------------------------------------------
-- Клиентское удаление окон уведомлений в PlayerGui
--------------------------------------------------

local function startGuiKiller()
    local pg = player:FindFirstChild("PlayerGui") or player:WaitForChild("PlayerGui")

    task.spawn(function()
        while true do
            for _, obj in ipairs(pg:GetDescendants()) do
                if obj:IsA("ScreenGui") or obj:IsA("Frame") or obj:IsA("TextLabel") or obj:IsA("ImageLabel") then
                    local name = obj.Name:lower()

                    -- Подстрой под реальные имена их GUI
                    if name:find("popup")
                        or name:find("winpopup")
                        or name:find("notification")
                        or name:find("reward")
                    then
                        obj:Destroy()
                    end
                end
            end

            task.wait(0.1)
        end
    end)
end

startGuiKiller()
