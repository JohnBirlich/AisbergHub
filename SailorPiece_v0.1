-- Sailor Piece Hub v1 (safe for Xeno / Wave / Solara)
if getgenv and getgenv().SailorPieceHubLoaded then return end
if getgenv then getgenv().SailorPieceHubLoaded = true end

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- безопасно создаём GUI
local ok, coreGui = pcall(function()
    return game:GetService("CoreGui")
end)
local parentGui = ok and coreGui or player:WaitForChild("PlayerGui")

local gui = Instance.new("ScreenGui")
gui.Name = "SailorPieceHub"
gui.ResetOnSpawn = false
gui.Parent = parentGui

-- простая рамка, без наворотов
local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 260, 0, 360)
frame.Position = UDim2.new(0, 20, 0, 20)
frame.BackgroundColor3 = Color3.fromRGB(20,20,30)

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "Sailor Piece Hub"
title.TextColor3 = Color3.new(1,1,1)
title.Font = Enum.Font.SourceSansBold
title.TextScaled = true

local scroll = Instance.new("ScrollingFrame", frame)
scroll.Size = UDim2.new(1,-10,1,-80)
scroll.Position = UDim2.new(0,5,0,40)
scroll.BackgroundTransparency = 1
scroll.ScrollBarThickness = 6

-- Чистый телепорт без Tween и прочего
local function tp(cf)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = cf
    end
end

-- ПРИМЕРНЫЕ координаты, ты подставишь реальные
local islands = {
    {name="Starter",      pos=CFrame.new(0,50,0)},
    {name="Sailor",       pos=CFrame.new(500,50,0)},
    {name="Jungle",       pos=CFrame.new(1000,50,500)},
    {name="Desert",       pos=CFrame.new(1500,50,1000)},
    {name="Snow",         pos=CFrame.new(2000,50,1500)},
    {name="Shibuya",      pos=CFrame.new(3000,100,2000)},
    {name="Hueco Mundo",  pos=CFrame.new(5000,50,3000)},
    {name="Judgment",     pos=CFrame.new(-5000,100,8000)},
    {name="Soul Society", pos=CFrame.new(12000,50,-3000)},
}

for i, isl in ipairs(islands) do
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(1,-10,0,30)
    btn.Position = UDim2.new(0,0,(i-1)*0.07,0)
    btn.Text = "TP: "..isl.name
    btn.BackgroundColor3 = Color3.fromRGB(0,140,0)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.SourceSans
    btn.TextScaled = true

    btn.MouseButton1Click:Connect(function()
        tp(isl.pos)
    end)
end
scroll.CanvasSize = UDim2.new(0,0,0,#islands*0.08)

-- AutoFarm toggle
local autoFarm = false

local toggle = Instance.new("TextButton", frame)
toggle.Size = UDim2.new(1,-20,0,30)
toggle.Position = UDim2.new(0,10,1,-35)
toggle.Text = "AutoFarm: OFF"
toggle.BackgroundColor3 = Color3.fromRGB(170,0,0)
toggle.TextColor3 = Color3.new(1,1,1)
toggle.Font = Enum.Font.SourceSansBold
toggle.TextScaled = true

toggle.MouseButton1Click:Connect(function()
    autoFarm = not autoFarm
    toggle.Text = "AutoFarm: "..(autoFarm and "ON" or "OFF")
    toggle.BackgroundColor3 = autoFarm and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
end)

-- Простой автофарм: ищем мобов по имени и бьём Tool’ом
task.spawn(function()
    while true do
        if autoFarm and player.Character then
            local char = player.Character
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                for _, mob in ipairs(workspace:GetChildren()) do
                    if mob:IsA("Model")
                        and mob:FindFirstChild("Humanoid")
                        and mob:FindFirstChild("HumanoidRootPart")
                        and (mob.Name:find("Mob") or mob.Name:find("Swordsman") or mob.Name:find("Quincy")) then

                        hrp.CFrame = mob.HumanoidRootPart.CFrame * CFrame.new(0,5,0)
                        local tool = char:FindFirstChildOfClass("Tool")
                        if tool then
                            pcall(function()
                                tool:Activate()
                            end)
                        end
                        task.wait(0.1)
                    end
                end
            end
        end
        task.wait(0.3)
    end
end)

print("[Sailor Piece Hub] Loaded")
