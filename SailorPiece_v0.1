    local RemoteEvents  = RS:WaitForChild("RemoteEvents")
    local TeleportUI    = Remotes:WaitForChild("OpenTeleportUI")
    local SafeZoneEvent = RemoteEvents:WaitForChild("SafeZoneEvent")

    --------------------------------------------------
    -- Islands + Hogyoku
    --------------------------------------------------

    local Islands = {
        {Name="StarterIsland",   Zone="Starter"},
        {Name="SailorIsland",    Zone="SailorIsland"},
        {Name="JungleIsland",    Zone="JungleIsland"},
        {Name="DesertIsland",    Zone="DesertIsland"},
        {Name="DungeonIsland",   Zone="DungeonIsland"},
        {Name="SnowIsland",      Zone="SnowIsland"},
        {Name="BossIsland",      Zone="BossIsland"},
        {Name="ShibuyaStation",  Zone="ShibuyaStation"},
        {Name="HuecoMundo",      Zone="HuecoMundo"},
        {Name="ShinjukuIsland",  Zone="ShinjukuIsland"},
        {Name="SlimeIsland",     Zone="SlimeIsland"},
        {Name="AcademyIsland",   Zone="AcademyIsland"},
        {Name="JudgmentIsland",  Zone="JudgmentIsland"},
        --{Name="SoulSociety",   Zone="SoulSociety"},
    }

    local HogyokuFragments = {
        {"Fragment1", CFrame.new(-424.589447, 56.6024628, -1235.32568, 0.289153755, 0.168311402, 0.942370117, -0.00750803947, 0.984790444, -0.173584118, -0.957253277, 0.0431171507, 0.286019504)},
        {"Fragment2", CFrame.new(1636.70898, 85.5206757, 247.291901, 0.989795089, 0, -0.142497987, 0, 1, 0, 0.142497987, 0, 0.989795089)},
        {"Fragment3", CFrame.new(-636.008423, 22.5490417, 1206.28113, 0.923217237, -0.345339119, 0.16855523, 0.381866992, 0.873522758, -0.301886827, -0.0429835021, 0.343072802, 0.938324809)},
        {"Fragment4", CFrame.new(648.099976, 137.94455, -2069.59741, 0.772088885, -0.631137073, 0.0744634345, 0.628663361, 0.775662899, 0.0559423678, -0.0930658206, 0.00361994654, 0.995653391)},
        {"Fragment5", CFrame.new(-1206.52283, 30.8849335, 463.206787, 0.993406057, -0.0171359815, 0.113360971, -0.00357546285, 0.983655572, 0.180024818, -0.114593059, -0.179243073, 0.977108181)},
        {"Fragment6", CFrame.new(-906.39801, 15.7299957, -1260.2478, 0.990366459, 0, -0.138471082, 0, 1, 0, 0.138471082, 0, 0.990366459)},
    }

    local function tpCFrame(cf)
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = cf
        end
    end

    local function serverTeleport(zoneName)
        if not zoneName then return end
        pcall(function()
            TeleportUI:FireServer("Open")
        end)
        SafeZoneEvent:FireServer("Changed", zoneName)
    end

    --------------------------------------------------
    -- Автофарм ядро (NPC's)
    --------------------------------------------------

    local AutoFarm = {
        Enabled = false,
        Mode = "nearest",
        Target = nil,
        MobNameFilter = {"Mob","Swordsman","Quincy"},
        Distance = 80,
        HeightOffset = 5,
    }

    function AutoFarm:SetMode(mode)
        self.Mode = mode
    end

    function AutoFarm:SetEnabled(state)
        self.Enabled = state
    end

    local function isValidCombatNPC(model)
        if not model:IsA("Model") then return false end
        if not model:FindFirstChild("Humanoid") then return false end
        if not model:FindFirstChild("HumanoidRootPart") then return false end
        if model.Humanoid.Health <= 0 then return false end
        for _, key in ipairs(AutoFarm.MobNameFilter) do
            if string.find(string.lower(model.Name), string.lower(key)) then
                return true
            end
        end
        return false
    end

    local function getNearestNPCFolder(originPos)
        local folder = workspace:FindFirstChild("NPC's")
        if not folder then return nil end
        local nearest, dist = nil, AutoFarm.Distance
        for _, npc in ipairs(folder:GetChildren()) do
            if isValidCombatNPC(npc) then
                local hrp = npc.HumanoidRootPart
                local d = (hrp.Position - originPos).Magnitude
                if d < dist then
                    dist = d
                    nearest = npc
                end
            end
        end
        return nearest
    end

    local function getOffsetCFrame(targetHRP)
        local base = targetHRP.CFrame
        local mode = AutoFarm.Mode
        if mode == "above" then
            return base * CFrame.new(0, AutoFarm.HeightOffset, 0)
        elseif mode == "below" then
            return base * CFrame.new(0, -AutoFarm.HeightOffset, 0)
        elseif mode == "back" then
            return base * CFrame.new(0, 0, -AutoFarm.HeightOffset)
        elseif mode == "nearest" then
            return base * CFrame.new(0, AutoFarm.HeightOffset, 0)
        end
        return base
    end

    RunService.Heartbeat:Connect(function()
        if not AutoFarm.Enabled then return end
        local char = LocalPlayer.Character
        if not (char and char:FindFirstChild("HumanoidRootPart")) then return end
        local myHRP = char.HumanoidRootPart

        if not AutoFarm.Target
            or not AutoFarm.Target.Parent
            or not AutoFarm.Target:FindFirstChild("Humanoid")
            or AutoFarm.Target.Humanoid.Health <= 0
        then
            AutoFarm.Target = getNearestNPCFolder(myHRP.Position)
        end

        local target = AutoFarm.Target
        if target and target:FindFirstChild("HumanoidRootPart") then
            local goalCF = getOffsetCFrame(target.HumanoidRootPart)
            myHRP.CFrame = goalCF
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then pcall(function() tool:Activate() end) end
        end
    end)

    --------------------------------------------------
    -- Instant Interaction для ProximityPrompt
    --------------------------------------------------

    local function applyInstantPrompt()
        for _, inst in ipairs(workspace:GetDescendants()) do
            if inst:IsA("ProximityPrompt") then
                inst.HoldDuration = 0.0001
                -- при желании:
                -- inst.MaxActivationDistance = 20
            end
        end
        print("[SailorPieceHub] Instant Interaction applied")
    end

    --------------------------------------------------
    -- Вкладки
    --------------------------------------------------

    local function buildIslandsTab()
        clearContent()
        local y = 0

        for _, isl in ipairs(Islands) do
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, -10, 0, 28)
            b.Position = UDim2.new(0, 0, 0, y)
            b.BackgroundColor3 = Color3.fromRGB(0,140,0)
            b.BorderSizePixel = 0
            b.Font = Enum.Font.Gotham
            b.Text = "TP: "..isl.Name
            b.TextColor3 = Color3.new(1,1,1)
            b.TextSize = 14
            b.Parent = content

            b.MouseButton1Click:Connect(function()
                serverTeleport(isl.Zone)
            end)

            y = y + 30
        end

        for _, data in ipairs(HogyokuFragments) do
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, -10, 0, 28)
            b.Position = UDim2.new(0, 0, 0, y)
            b.BackgroundColor3 = Color3.fromRGB(120,60,0)
            b.BorderSizePixel = 0
            b.Font = Enum.Font.Gotham
            b.Text = "TP Hogyoku "..data[1]
            b.TextColor3 = Color3.new(1,1,1)
            b.TextSize = 14
            b.Parent = content

            b.MouseButton1Click:Connect(function()
                tpCFrame(data[2])
            end)

            y = y + 30
        end

        content.CanvasSize = UDim2.new(0,0,0,y+10)
    end

    local function buildMobsTab()
        clearContent()
        local y = 0
        local modes = {"nearest","above","back","below"}
        for _, m in ipairs(modes) do
            local b = Instance.new("TextButton")
            b.Size = UDim2.new(1, -10, 0, 28)
            b.Position = UDim2.new(0, 0, 0, y)
            b.BackgroundColor3 = Color3.fromRGB(60,60,110)
            b.BorderSizePixel = 0
            b.Font = Enum.Font.Gotham
            b.Text = "Mode: "..m
            b.TextColor3 = Color3.new(1,1,1)
            b.TextSize = 14
            b.Parent = content
            b.MouseButton1Click:Connect(function()
                AutoFarm:SetMode(m)
            end)
            y = y + 30
        end

        local lab = Instance.new("TextLabel")
        lab.Size = UDim2.new(1, -10, 0, 40)
        lab.Position = UDim2.new(0, 0, 0, y+5)
        lab.BackgroundTransparency = 1
        lab.Font = Enum.Font.Gotham
        lab.Text = "Mob filter:\nMob, Swordsman, Quincy"
        lab.TextColor3 = Color3.new(1,1,1)
        lab.TextSize = 14
        lab.TextWrapped = true
        lab.Parent = content

        content.CanvasSize = UDim2.new(0,0,0,y+60)
    end

    local function buildBossesTab()
        clearContent()
        local folder = workspace:FindFirstChild("NPC's")
        local y = 0
        if folder then
            for _, npc in ipairs(folder:GetChildren()) do
                if npc:IsA("Model") and npc:FindFirstChild("Humanoid") then
                    local b = Instance.new("TextButton")
                    b.Size = UDim2.new(1, -10, 0, 28)
                    b.Position = UDim2.new(0, 0, 0, y)
                    b.BackgroundColor3 = Color3.fromRGB(120,0,0)
                    b.BorderSizePixel = 0
                    b.Font = Enum.Font.Gotham
                    b.Text = "TP Boss: "..npc.Name
                    b.TextColor3 = Color3.new(1,1,1)
                    b.TextSize = 14
                    b.Parent = content
                    b.MouseButton1Click:Connect(function()
                        local hrp = npc:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            tpCFrame(hrp.CFrame * CFrame.new(0, AutoFarm.HeightOffset, 0))
                        end
                    end)
                    y = y + 30
                end
            end
        end
        content.CanvasSize = UDim2.new(0,0,0,y+10)
    end

    local function buildNPCsTab()
        clearContent()
        local folder = workspace:FindFirstChild("ServiceNPC's")
        local y = 0
        if folder then
            for _, npc in ipairs(folder:GetChildren()) do
                if npc:IsA("Model") and npc:FindFirstChild("HumanoidRootPart") then
                    local b = Instance.new("TextButton")
                    b.Size = UDim2.new(1, -10, 0, 28)
                    b.Position = UDim2.new(0, 0, 0, y)
                    b.BackgroundColor3 = Color3.fromRGB(0,80,140)
                    b.BorderSizePixel = 0
                    b.Font = Enum.Font.Gotham
                    b.Text = "TP NPC: "..npc.Name
                    b.TextColor3 = Color3.new(1,1,1)
                    b.TextSize = 14
                    b.Parent = content
                    b.MouseButton1Click:Connect(function()
                        tpCFrame(npc.HumanoidRootPart.CFrame * CFrame.new(0, AutoFarm.HeightOffset, 0))
                    end)
                    y = y + 30
                end
            end
        end

        -- кнопка Instant Interaction
        local instantBtn = Instance.new("TextButton")
        instantBtn.Size = UDim2.new(1, -10, 0, 28)
        instantBtn.Position = UDim2.new(0, 0, 0, y + 5)
        instantBtn.BackgroundColor3 = Color3.fromRGB(90, 140, 255)
        instantBtn.BorderSizePixel = 0
        instantBtn.Font = Enum.Font.GothamBold
        instantBtn.Text = "Instant Interaction (Prompts)"
        instantBtn.TextColor3 = Color3.new(1,1,1)
        instantBtn.TextSize = 14
        instantBtn.Parent = content

        instantBtn.MouseButton1Click:Connect(applyInstantPrompt)

        content.CanvasSize = UDim2.new(0,0,0,y+40)
    end

    -- первая вкладка
    buildIslandsTab()

    RunService.RenderStepped:Connect(function()
        if currentTab == "Islands" then
            if not content:FindFirstChildOfClass("TextButton") then
                buildIslandsTab()
            end
        elseif currentTab == "Mobs" then
            if not content:FindFirstChildOfClass("TextButton") then
                buildMobsTab()
            end
        elseif currentTab == "Bosses" then
            if not content:FindFirstChildOfClass("TextButton") then
                buildBossesTab()
            end
        elseif currentTab == "NPCs" then
            if not content:FindFirstChildOfClass("TextButton") then
                buildNPCsTab()
            end
        end
    end)

    -- нижний тоггл автофарма
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(1,-20,0,30)
    toggle.Position = UDim2.new(0,10,0,5)
    toggle.BackgroundColor3 = Color3.fromRGB(170,0,0)
    toggle.BorderSizePixel = 0
    toggle.Font = Enum.Font.GothamBold
    toggle.Text = "AutoFarm: OFF"
    toggle.TextColor3 = Color3.new(1,1,1)
    toggle.TextSize = 14
    toggle.Parent = bottom

    toggle.MouseButton1Click:Connect(function()
        AutoFarm.Enabled = not AutoFarm.Enabled
        toggle.Text = "AutoFarm: "..(AutoFarm.Enabled and "ON" or "OFF")
        toggle.BackgroundColor3 = AutoFarm.Enabled and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
    end)

    print("[SailorPieceHub] Loaded")
end

