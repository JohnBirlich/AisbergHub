    ghFrame.Size = UDim2.new(1, 0, 0, 90)
    ghFrame.BackgroundColor3 = PANEL_DARK
    ghFrame.BorderSizePixel = 0
    ghFrame.Parent = leftColumn
    round(ghFrame,4)

    local ghTitle = menuTitle:Clone()
    ghTitle.Text = "> GITHUB"
    ghTitle.Parent = ghFrame

    local ghText = Instance.new("TextLabel")
    ghText.Size = UDim2.new(1, -12, 1, -26)
    ghText.Position = UDim2.new(0,6,0,24)
    ghText.BackgroundTransparency = 1
    ghText.Font = REGULAR_FONT
    ghText.TextSize = 13
    ghText.TextColor3 = TEXT_MAIN
    ghText.TextXAlignment = Enum.TextXAlignment.Left
    ghText.TextYAlignment = Enum.TextYAlignment.Top
    ghText.TextWrapped = true
    ghText.Text = "Thanks for using Aisberg Hub!\nAn open source code!"
    ghText.Parent = ghFrame

    -- Configuration
    local cfgFrame = Instance.new("Frame")
    cfgFrame.Size = UDim2.new(1, 0, 0, 260)
    cfgFrame.BackgroundColor3 = PANEL_DARK
    cfgFrame.BorderSizePixel = 0
    cfgFrame.Parent = rightColumn
    round(cfgFrame,4)

    local cfgTitle = menuTitle:Clone()
    cfgTitle.Text = "> CONFIGURATION"
    cfgTitle.Parent = cfgFrame

    local cfgContent = Instance.new("Frame")
    cfgContent.Size = UDim2.new(1, -12, 1, -26)
    cfgContent.Position = UDim2.new(0,6,0,24)
    cfgContent.BackgroundTransparency = 1
    cfgContent.Parent = cfgFrame

    local cfgLayout = Instance.new("UIListLayout")
    cfgLayout.Parent = cfgContent
    cfgLayout.Padding = UDim.new(0,4)

    local nameFrame = Instance.new("Frame")
    nameFrame.Size = UDim2.new(1, 0, 0, 24)
    nameFrame.BackgroundTransparency = 1
    nameFrame.Parent = cfgContent

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0.4, -5, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = REGULAR_FONT
    nameLabel.TextSize = 13
    nameLabel.TextColor3 = TEXT_MAIN
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Text = "Config name"
    nameLabel.Parent = nameFrame

    local nameBox = Instance.new("TextBox")
    nameBox.Size = UDim2.new(0.6, 0, 1, 0)
    nameBox.Position = UDim2.new(0.4, 0, 0, 0)
    nameBox.BackgroundColor3 = Color3.fromRGB(0,30,0)
    nameBox.BorderSizePixel = 0
    nameBox.Font = REGULAR_FONT
    nameBox.TextSize = 13
    nameBox.TextColor3 = TEXT_MAIN
    nameBox.PlaceholderText = "enter config name"
    nameBox.Text = ""
    nameBox.Parent = nameFrame
    round(nameBox,3)

    local Configs = {}
    local CurrentConfig = nil

    local listFrame = Instance.new("Frame")
    listFrame.Size = UDim2.new(1, 0, 0, 80)
    listFrame.BackgroundColor3 = Color3.fromRGB(0,15,0)
    listFrame.BorderSizePixel = 0
    listFrame.Parent = cfgContent
    round(listFrame,3)

    local listLabel = Instance.new("TextLabel")
    listLabel.Size = UDim2.new(1, -8, 0, 18)
    listLabel.Position = UDim2.new(0,4,0,2)
    listLabel.BackgroundTransparency = 1
    listLabel.Font = REGULAR_FONT
    listLabel.TextSize = 13
    listLabel.TextColor3 = TEXT_MAIN
    listLabel.TextXAlignment = Enum.TextXAlignment.Left
    listLabel.Text = "Config list:"
    listLabel.Parent = listFrame

    local listScroll = Instance.new("ScrollingFrame")
    listScroll.Size = UDim2.new(1, -8, 1, -22)
    listScroll.Position = UDim2.new(0,4,0,20)
    listScroll.BackgroundTransparency = 1
    listScroll.ScrollBarThickness = 3
    listScroll.CanvasSize = UDim2.new(0,0,0,0)
    listScroll.Parent = listFrame

    local listLayout = Instance.new("UIListLayout")
    listLayout.Parent = listScroll
    listLayout.Padding = UDim.new(0,2)

    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        listScroll.CanvasSize = UDim2.new(0,0,0,listLayout.AbsoluteContentSize.Y)
    end)

    local function rebuildConfigList()
        for _, child in ipairs(listScroll:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        if next(Configs) == nil then
            local empty = Instance.new("TextButton")
            empty.Size = UDim2.new(1, 0, 0, 18)
            empty.BackgroundColor3 = Color3.fromRGB(0,20,0)
            empty.BorderSizePixel = 0
            empty.Font = REGULAR_FONT
            empty.TextSize = 12
            empty.TextColor3 = TEXT_SUB
            empty.Text = "---"
            empty.AutoButtonColor = false
            empty.Parent = listScroll
            round(empty,2)
            return
        end
        for name,_ in pairs(Configs) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 18)
            btn.BackgroundColor3 = Color3.fromRGB(0,20,0)
            btn.BorderSizePixel = 0
            btn.Font = REGULAR_FONT
            btn.TextSize = 12
            btn.TextColor3 = TEXT_MAIN
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.Text = name
            btn.Parent = listScroll
            round(btn,2)
            btn.MouseButton1Click:Connect(function()
                nameBox.Text = name
            end)
        end
    end

    rebuildConfigList()

    local function smallButton(text)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1, 0, 0, 22)
        b.BackgroundColor3 = Color3.fromRGB(0,30,0)
        b.BorderSizePixel = 0
        b.Font = REGULAR_FONT
        b.TextSize = 13
        b.TextColor3 = TEXT_MAIN
        b.Text = text
        b.AutoButtonColor = true
        round(b,3)
        b.Parent = cfgContent
        return b
    end

    local createBtn    = smallButton("Create config")
    local loadBtn      = smallButton("Load config")
    local overwriteBtn = smallButton("Overwrite config")
    local deleteBtn    = smallButton("Delete config")
    local refreshBtn   = smallButton("Refresh list")
    local setAutoBtn   = smallButton("Set as autoload")
    local resetAutoBtn = smallButton("Reset autoload")

    local autoLabel = Instance.new("TextLabel")
    autoLabel.Size = UDim2.new(1, 0, 0, 18)
    autoLabel.BackgroundTransparency = 1
    autoLabel.Font = REGULAR_FONT
    autoLabel.TextSize = 13
    autoLabel.TextColor3 = TEXT_SUB
    autoLabel.TextXAlignment = Enum.TextXAlignment.Left
    autoLabel.Text = "Current autoload config: none"
    autoLabel.Parent = cfgContent

    local function getCurrentName()
        local n = nameBox.Text
        if n == nil or n == "" then return nil end
        return n
    end

    local function captureCurrentConfig()
        return {
            MainConfig      = MainCfg,
            CombatConfig    = CombatCfg,
            FarmConfig      = FarmCfg,
            QuestConfig     = QuestCfg,
            StatsConfig     = StatsCfg,
            TeleportConfig  = TeleportCfg,
            SettingsConfig  = SettingsCfg,
        }
    end

    local function applyConfigData(data)
        if not data then return end
        _G.MainConfig      = data.MainConfig or _G.MainConfig
        _G.CombatConfig    = data.CombatConfig or _G.CombatConfig
        _G.FarmConfig      = data.FarmConfig or _G.FarmConfig
        _G.QuestConfig     = data.QuestConfig or _G.QuestConfig
        _G.StatsConfig     = data.StatsConfig or _G.StatsConfig
        _G.TeleportConfig  = data.TeleportConfig or _G.TeleportConfig
        _G.SettingsConfig  = data.SettingsConfig or _G.SettingsConfig
    end

    createBtn.MouseButton1Click:Connect(function()
        local name = getCurrentName()
        if not name then return end
        Configs[name] = captureCurrentConfig()
        CurrentConfig = name
        rebuildConfigList()
    end)

    loadBtn.MouseButton1Click:Connect(function()
        local name = getCurrentName()
        if not name then return end
        applyConfigData(Configs[name])
    end)

    overwriteBtn.MouseButton1Click:Connect(function()
        local name = getCurrentName()
        if not name then return end
        if not Configs[name] then return end
        Configs[name] = captureCurrentConfig()
    end)

    deleteBtn.MouseButton1Click:Connect(function()
        local name = getCurrentName()
        if not name then return end
        Configs[name] = nil
        if SettingsCfg.AutoLoadConfigName == name then
            SettingsCfg.AutoLoadConfigName = nil
            autoLabel.Text = "Current autoload config: none"
        end
        if CurrentConfig == name then
            CurrentConfig = nil
        end
        rebuildConfigList()
    end)

    refreshBtn.MouseButton1Click:Connect(function()
        rebuildConfigList()
    end)

    setAutoBtn.MouseButton1Click:Connect(function()
        local name = getCurrentName()
        if not name then return end
        if not Configs[name] then return end
        SettingsCfg.AutoLoadConfigName = name
        autoLabel.Text = "Current autoload config: "..name
    end)

    resetAutoBtn.MouseButton1Click:Connect(function()
        SettingsCfg.AutoLoadConfigName = nil
        autoLabel.Text = "Current autoload config: none"
    end)
end

