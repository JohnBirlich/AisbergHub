    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 46, 0, 18)
    btn.Position = UDim2.new(1, -48, 0.5, -9)
    btn.BackgroundColor3 = default and ACCENT_COLOR or Color3.fromRGB(0, 40, 0)
    btn.BorderSizePixel = 0
    btn.Text = default and "ON" or "OFF"
    btn.Font = BOLD_FONT
    btn.TextSize = 11
    btn.TextColor3 = Color3.fromRGB(0, 0, 0)
    btn.Parent = frame
    round(btn, 9)

    local state = default

    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.BackgroundColor3 = state and ACCENT_COLOR or Color3.fromRGB(0, 40, 0)
        btn.Text = state and "ON" or "OFF"
        if callback then
            pcall(callback, state)
        end
    end)

    return frame
end

local function SliderBar(parent, labelText, min, max, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 38)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 18)
    label.BackgroundTransparency = 1
    label.Font = REGULAR_FONT
    label.TextSize = 13
    label.TextColor3 = TEXT_MAIN
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Text = labelText .. " (" .. tostring(default) .. ")"
    label.Parent = frame

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(1, -10, 0, 6)
    bar.Position = UDim2.new(0, 5, 0, 22)
    bar.BackgroundColor3 = Color3.fromRGB(0, 40, 0)
    bar.BorderSizePixel = 0
    bar.Parent = frame
    round(bar, 3)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
    fill.BackgroundColor3 = ACCENT_COLOR
    fill.BorderSizePixel = 0
    fill.Parent = bar
    round(fill, 3)

    local dragging = false

    local function setValueFromX(x)
        local rel = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        local value = min + (max - min) * rel
        fill.Size = UDim2.new(rel, 0, 1, 0)
        label.Text = labelText .. " (" .. string.format("%.2f", value) .. ")"
        if callback then
            pcall(callback, value)
        end
    end

    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            IsDraggingSlider = true
            setValueFromX(input.Position.X)
        end
    end)

    bar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
            IsDraggingSlider = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            setValueFromX(input.Position.X)
        end
    end)

    if callback then
        pcall(callback, default)
    end

    return frame
end

local function DropdownSimple(parent, labelText, options, defaultIndex, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 24)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.4, -5, 1, 0)
    label.BackgroundTransparency = 1
    label.Font = REGULAR_FONT
    label.TextSize = 13
    label.TextColor3 = TEXT_MAIN
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Text = labelText
    label.Parent = frame

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.6, 0, 1, 0)
    btn.Position = UDim2.new(0.4, 0, 0, 0)
    btn.BackgroundColor3 = Color3.fromRGB(0, 30, 0)
    btn.BorderSizePixel = 0
    btn.Font = REGULAR_FONT
    btn.TextSize = 13
    btn.TextColor3 = TEXT_SUB
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Text = options[defaultIndex] or ""
    btn.Parent = frame
    round(btn, 3)
    addStroke(btn, 1, Color3.fromRGB(0, 60, 0), 0.4)

    local open = false
    local listFrame

    local function setOption(opt)
        btn.Text = opt
        if callback then
            pcall(callback, opt)
        end
    end

    btn.MouseButton1Click:Connect(function()
        if open then
            if listFrame then listFrame:Destroy() end
            open = false
            return
        end
        open = true

        listFrame = Instance.new("Frame")
        listFrame.Size = UDim2.new(1, 0, 0, math.min(#options*20+4, 140))
        listFrame.Position = UDim2.new(0, 0, 1, 2)
        listFrame.BackgroundColor3 = Color3.fromRGB(0, 10, 0)
        listFrame.BorderSizePixel = 0
        listFrame.Parent = btn
        round(listFrame, 3)
        addStroke(listFrame, 1, Color3.fromRGB(0, 60, 0), 0.6)

        local scroll = Instance.new("ScrollingFrame")
        scroll.Size = UDim2.new(1, -4, 1, -4)
        scroll.Position = UDim2.new(0, 2, 0, 2)
        scroll.BackgroundTransparency = 1
        scroll.ScrollBarThickness = 3
        scroll.CanvasSize = UDim2.new(0,0,0,0)
        scroll.Parent = listFrame

        local layout = Instance.new("UIListLayout")
        layout.Parent = scroll
        layout.Padding = UDim.new(0, 2)

        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            scroll.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
        end)

        for _, opt in ipairs(options) do
            local oBtn = Instance.new("TextButton")
            oBtn.Size = UDim2.new(1, 0, 0, 18)
            oBtn.BackgroundColor3 = Color3.fromRGB(0, 20, 0)
            oBtn.BorderSizePixel = 0
            oBtn.Font = REGULAR_FONT
            oBtn.TextSize = 12
            oBtn.TextColor3 = TEXT_SUB
            oBtn.TextXAlignment = Enum.TextXAlignment.Left
            oBtn.Text = opt
            oBtn.Parent = scroll
            round(oBtn, 2)

            oBtn.MouseButton1Click:Connect(function()
                setOption(opt)
                listFrame:Destroy()
                open = false
            end)
        end
    end)

    setOption(options[defaultIndex] or options[1])

    return frame
end

