    unloadBtn.TextSize = 13
    unloadBtn.TextColor3 = Color3.fromRGB(255,80,80)
    unloadBtn.Text = "UNLOAD SCRIPT"
    unloadBtn.Parent = menuContent
    round(unloadBtn,4)

    unloadBtn.MouseButton1Click:Connect(function()
        ScreenGui:Destroy()
    end)

    -- Github
