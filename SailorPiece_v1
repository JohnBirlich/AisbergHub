local fpsLabel    = makeStatLabel("FPS: 0")
local pingLabel   = makeStatLabel("Ping: 0 ms")
local levelLabel  = makeStatLabel("Level: 0")
local bountyLabel = makeStatLabel("Bounty: 0")
local hoursLabel  = makeStatLabel("Script uptime: 0.00 h")

local scriptStartTime = tick()
local framesCounter = 0

RunService.RenderStepped:Connect(function()
    framesCounter += 1
end)

task.spawn(function()
    while true do
        local fps = framesCounter
        framesCounter = 0
        fpsLabel.Text = ("FPS: %d"):format(fps)

        local pingMs = 0
        pcall(function()
            local p = LocalPlayer
            if p then
                pingMs = math.floor(p:GetNetworkPing() * 2000)
            end
        end)
        pingLabel.Text = ("Ping: %d ms"):format(pingMs)

        local level = 0
        local bounty = 0
        pcall(function()
            local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
            if leaderstats then
                local lvlValue = leaderstats:FindFirstChild("Level") or leaderstats:FindFirstChild("Lvl")
                if lvlValue then level = lvlValue.Value end
                local bountyValue = leaderstats:FindFirstChild("Bounty")
                if bountyValue then bounty = bountyValue.Value end
            end
        end)
        levelLabel.Text  = ("Level: %s"):format(level)
        bountyLabel.Text = ("Bounty: %s"):format(bounty)

        local elapsed = tick() - scriptStartTime
        local hours = elapsed / 3600
        hoursLabel.Text = ("Script uptime: %.2f h"):format(hours)

        task.wait(1)
    end
end)

