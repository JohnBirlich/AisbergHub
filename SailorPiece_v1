UserInputService.InputChanged:Connect(function(input)
    if draggingMain and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- Minimize (tween)
local isMinimized = false
local fullSize = MainFrame.Size
local fullPosition = MainFrame.Position
local minimizedSize = UDim2.new(fullSize.X.Scale, fullSize.X.Offset, 0, 40)
local minimizedPosition = fullPosition

local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local currentTween

local function applyMinimize(state)
    isMinimized = state
    if currentTween then currentTween:Cancel() end

    if state then
        ContentHolder.Visible = false
        currentTween = TweenService:Create(MainFrame, tweenInfo, {
            Size = minimizedSize,
            Position = minimizedPosition
        })
        currentTween:Play()
    else
        currentTween = TweenService:Create(MainFrame, tweenInfo, {
            Size = fullSize,
            Position = fullPosition
        })
        currentTween:Play()
        currentTween.Completed:Connect(function()
            if not isMinimized then
                ContentHolder.Visible = true
            end
        end)
    end
end

MinimizeBtn.MouseButton1Click:Connect(function()
    applyMinimize(not isMinimized)
end)

TitleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingMain = false
        if not isMinimized then
            fullPosition = MainFrame.Position
        end
    end
end)

