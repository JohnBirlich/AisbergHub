    bindButton.BorderSizePixel = 0
    bindButton.Font = REGULAR_FONT
    bindButton.TextSize = 13
    bindButton.TextColor3 = TEXT_SUB
    bindButton.Text = SettingsCfg.MenuKey.Name or "G"
    bindButton.Parent = bindFrame
    round(bindButton,3)

    local waitingForKey = false
    bindButton.MouseButton1Click:Connect(function()
        if waitingForKey then return end
        waitingForKey = true
        bindButton.Text = "[press key]"
        local conn
        conn = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                SettingsCfg.MenuKey = input.KeyCode
                bindButton.Text = SettingsCfg.MenuKey.Name
                waitingForKey = false
                if conn then conn:Disconnect() end
            end
        end)
    end)

    local unloadBtn = Instance.new("TextButton")
    unloadBtn.Size = UDim2.new(1, 0, 0, 26)
    unloadBtn.BackgroundColor3 = Color3.fromRGB(40,0,0)
