-- Aisberg Hub | +1 Aura Speed Escape
-- Auto tween TP start <-> end

local Players      = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UIS          = game:GetService("UserInputService")

local player = Players.LocalPlayer

local START_CF = CFrame.new(-592.599365, 36.1112404, 2004.25488, 1,0,0, 0,1,0, 0,0,1)
local END_CF   = CFrame.new(-565.550415, 20.2728081, -6068.28613, -1,0,0, 0,1,0, 0,0,-1)

local running      = false
local currentTween = nil

local function getCharAndHum()
    local char = player.Character or player.CharacterAdded:Wait()
    local hum  = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid")
    return char, hum
end

local function tweenTo(tag, targetCF, duration)
    local char, hum = getCharAndHum()
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then
        warn("[AisbergHub] No HumanoidRootPart")
        return
    end

    hum.PlatformStand = true

    local cfValue = Instance.new("CFrameValue")
    cfValue.Value = root.CFrame

    cfValue.Changed:Connect(function(newCF)
        char:PivotTo(newCF)
    end)

    if currentTween then
        currentTween:Cancel()
    end

    local info = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
    currentTween = TweenService:Create(cfValue, info, { Value = targetCF })
    currentTween:Play()

    currentTween.Completed:Wait()
    cfValue:Destroy()
    hum.PlatformStand = false
end

local function loopTween()
    if running then return end
    running = true
    print("[AisbergHub] Tween auto TP started")

    task.spawn(function()
        while running do
            tweenTo("START->END", END_CF, 2)  -- 2 сек до финиша
            if not running then break end
            task.wait(1)                      -- 1 сек ожидания
            tweenTo("END->START", START_CF, 2)
            if not running then break end
            task.wait(0.2)
        end

        if currentTween then
            currentTween:Cancel()
            currentTween = nil
        end
        print("[AisbergHub] Tween auto TP stopped")
    end)
end

--------------------------------------------------
-- GUI
--------------------------------------------------

local gui = Instance.new("ScreenGui")
gui.Name = "AisbergHub_AuraTween"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 260, 0, 100)
frame.Position = UDim2.new(0.6, -130, 0.5, -50)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
frame.BorderSizePixel = 0
frame.Active = true
frame.Parent = gui

-- Drag
local dragging, dragStart, startPos
frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

local titleBar = Instance.new("Frame")
titleBar.Size = UDim2.new(1, 0, 0, 24)
titleBar.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
titleBar.BorderSizePixel = 0
titleBar.Parent = frame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -24, 1, 0)
title.Position = UDim2.new(0, 4, 0, 0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.Text = "Aisberg Hub | Aura Speed Escape"
title.TextColor3 = Color3.new(1, 1, 1)
