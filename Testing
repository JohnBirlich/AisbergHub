-- +1 Aura Speed Escape – Auto Start/End Teleport
-- AisbergHub simple GUI

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- Точки
local START_CF = CFrame.new(
    -592.599365, 36.1112404, 2004.25488,
    1, 0, 0,
    0, 1, 0,
    0, 0, 1
)

local END_CF = CFrame.new(
    -565.550415, 20.2728081, -6068.28613,
    -1, 0, 0,
    0, 1, 0,
    0, 0, -1
)

-- Состояние
local running = false

local function getCharAndHum()
    local char = player.Character or player.CharacterAdded:Wait()
    local hum = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid")
    return char, hum
end

local function safeTeleport(cf)
    local char, hum = getCharAndHum()
    hum.PlatformStand = true
    char:PivotTo(cf)
    task.wait(0.1)
    hum.PlatformStand = false
end

local function loopTeleport()
    if running then return end
    running = true
    print("[AisbergHub] Aura Speed Escape auto TP started")

    task.spawn(function()
        while running do
            safeTeleport(START_CF)
            task.wait(0.1)
            safeTeleport(END_CF)
            task.wait(1)
        end

        print("[AisbergHub] Aura Speed Escape auto TP stopped")
    end)
end

--------------------------------------------------
-- GUI
--------------------------------------------------

local gui = Instance.new("ScreenGui")
gui.Name = "AuraSpeedEscape_AutoTP"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 90)
frame.Position = UDim2.new(0.6, -110, 0.5, -45)
frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
frame.BorderSizePixel = 0
frame.Active = true
frame.Parent = gui

-- перетаскивание
local dragging, dragStart, startPos
frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

local titleBar = Instance.new("Frame")
titleBar.Size = UDim2.new(1, 0, 0, 24)
titleBar.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
titleBar.BorderSizePixel = 0
titleBar.Parent = frame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -24, 1, 0)
title.Position = UDim2.new(0, 4, 0, 0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.Text = "+1 Aura Speed Escape"
title.TextColor3 = Color3.new(1, 1, 1)
title.TextSize = 14
title.TextXAlignment = Enum.TextXAlignment.Left
title.Parent = titleBar

-- Крестик
local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 24, 1, 0)
closeBtn.Position = UDim2.new(1, -24, 0, 0)
closeBtn.BackgroundTransparency = 1
closeBtn.Font = Enum.Font.GothamBold
closeBtn.Text = "X"
closeBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
closeBtn.TextSize = 16
closeBtn.Parent = titleBar

closeBtn.MouseButton1Click:Connect(function()
    running = false
    gui:Destroy()
end)

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(1, -20, 0, 40)
toggleBtn.Position = UDim2.new(0, 10, 0, 34)
toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 70, 70)
toggleBtn.BorderSizePixel = 0
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.Text = "Auto TP: OFF"
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
toggleBtn.TextSize = 14
toggleBtn.Parent = frame

toggleBtn.MouseButton1Click:Connect(function()
    running = not running
    if running then
        toggleBtn.Text = "Auto TP: ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(70, 160, 90)
        loopTeleport()
    else
        toggleBtn.Text = "Auto TP: OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 70, 70)
    end
end)

--------------------------------------------------
-- Тоггл GUI на G (если крестик не хочешь юзать)
--------------------------------------------------

UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.G then
        if gui and gui.Parent then
            gui.Enabled = not gui.Enabled
            print("[AisbergHub] GUI toggled, Enabled =", gui.Enabled)
        end
    end
end)
