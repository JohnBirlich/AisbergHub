-- Aura Speed Escape – Auto Start/End TP
-- AisbergHub style

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- Точки
local START_CF = CFrame.new(
    -592.599365, 36.1112404, 2004.25488,
    1, 0, 0,
    0, 1, 0,
    0, 0, 1
)

local END_CF = CFrame.new(
    -565.550415, 20.2728081, -6068.28613,
    -1, 0, 0,
    0, 1, 0,
    0, 0, -1
)

-- Состояние
local running = false

-- Получение HRP
local function getHRP()
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

-- Основной цикл
local function loopTeleport()
    if running then return end
    running = true
    print("[AisbergHub] Aura Speed Escape auto TP started")

    task.spawn(function()
        while running do
            local hrp = getHRP()

            -- Старт -> Финиш
            hrp.CFrame = START_CF
            task.wait(0.1) -- на всякий
            hrp.CFrame = END_CF

            -- Ожидание 1 сек
            task.wait(1)

            -- Финиш -> Старт
            if not running then break end
            hrp = getHRP()
            hrp.CFrame = START_CF

            -- Можно добавить ещё одну задержку, если нужно
            task.wait(0.1)
        end

        print("[AisbergHub] Aura Speed Escape auto TP stopped")
    end)
end

--------------------------------------------------
-- Простое меню
--------------------------------------------------

local gui = Instance.new("ScreenGui")
gui.Name = "AuraSpeedEscape_AutoTP"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 90)
frame.Position = UDim2.new(0.6, -110, 0.5, -45)
frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
frame.BorderSizePixel = 0
frame.Active = true
frame.Parent = gui

-- перетаскивание
local dragging, dragStart, startPos
frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 24)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.Text = "Aura Speed Escape"
title.TextColor3 = Color3.new(1, 1, 1)
title.TextSize = 16
title.Parent = frame

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(1, -20, 0, 40)
toggleBtn.Position = UDim2.new(0, 10, 0, 30)
toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 70, 70)
toggleBtn.BorderSizePixel = 0
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.Text = "Auto TP: OFF"
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
toggleBtn.TextSize = 14
toggleBtn.Parent = frame

toggleBtn.MouseButton1Click:Connect(function()
    running = not running
    if running then
        toggleBtn.Text = "Auto TP: ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(70, 160, 90)
        loopTeleport()
    else
        toggleBtn.Text = "Auto TP: OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 70, 70)
    end
end)
