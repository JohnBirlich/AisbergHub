local settings = {
    baseInterval        = 60,
    jitter              = 0.4,
    unfocusedMultiplier = 0.7,
    burstChance         = 0.15,
}

local function randRange(a, b)
    return a + math.random() * (b - a)
end

local function nextWait()
    local base     = settings.baseInterval
    local jitter   = base * settings.jitter
    local waitTime = base + randRange(-jitter, jitter)

    if math.random() < 0.10 then
        waitTime = waitTime + randRange(15, 45)
    end

    if not environment.isWindowFocused then
        waitTime = waitTime * settings.unfocusedMultiplier
    end

    return math.max(8, waitTime)
end

