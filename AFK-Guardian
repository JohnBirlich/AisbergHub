--------------------------------------------------
-- Drag + collapse + appear
--------------------------------------------------

local expandedSize  = UDim2.new(0, 420, 0, 210)
local collapsedSize = UDim2.new(0, 220, 0, 48)
local expandedPos   = UDim2.new(0, 40, 0, 80)
local collapsedPos  = UDim2.new(0, 40, 0, 40)
local isCollapsed   = false

-- drag по titleHitbox
do
    local dragging   = false
    local dragInput  = nil
    local dragStart  = nil
    local startPos   = nil

    local function update(input)
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end

    titleHitbox.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = input.Position
            startPos  = mainFrame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    titleHitbox.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

local function setVisibleState(collapsed)
    isCollapsed = collapsed
    local info = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local targetSize = collapsed and collapsedSize or expandedSize
    local targetPos  = collapsed and collapsedPos  or expandedPos

    TweenService:Create(mainFrame, info, {
        Size     = targetSize,
        Position = targetPos
    }):Play()

    contentFrame.Visible = not collapsed

    if collapsed then
        local status = AisbergGuardian.enabled and "[ON]" or "[OFF]"
        titleLabel.Text = "Aisberg Guardian " .. status
    else
        titleLabel.Text = "Aisberg Guardian :: Windows Terminal"
    end
end

-- appear from collapsed -> expanded
do
    mainFrame.Size = collapsedSize
    mainFrame.Position = collapsedPos
    mainFrame.BackgroundTransparency = 1
    mainStroke.Transparency = 1

    local info = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    TweenService:Create(mainFrame, info, {
        BackgroundTransparency = 0,
        Size = expandedSize,
        Position = expandedPos
    }):Play()
    TweenService:Create(mainStroke, info, {
        Transparency = 0.45
    }):Play()
end

titleHitbox.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        setVisibleState(not isCollapsed)
    end
end)

toggleButton.MouseButton2Click:Connect(function()
    setVisibleState(not isCollapsed)
end)

-- простой ресайз за правый нижний угол
do
    local resizing = false
    local startSize
    local startMouse

    resizeCorner.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing   = true
            startSize  = mainFrame.Size
            startMouse = input.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    resizing = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - startMouse
            local newW = math.max(260, startSize.X.Offset + delta.X)
            local newH = math.max(80,  startSize.Y.Offset + delta.Y)

            mainFrame.Size = UDim2.new(0, newW, 0, newH)
        end
    end)
end

