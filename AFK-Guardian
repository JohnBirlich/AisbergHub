        externalLabel.TextColor3 = Color3.fromRGB(255, 210, 80)
    else
        externalLabel.Text = "external: none"
        externalLabel.TextColor3 = Color3.fromRGB(140, 200, 255)
    end
end

local function cleanup()
    AisbergGuardian.enabled = false
    stopIdledHook()

    for _, conn in ipairs(AisbergGuardian.connections) do
        pcall(function()
            conn:Disconnect()
        end)
    end

    pcall(function()
        if screenGui then
            screenGui:Destroy()
        end
    end)

    if getgenv then
        getgenv().AisbergGuardianLoaded = nil
    end

    warn("[Aisberg Guardian] Unloaded and cleaned up.")
end

