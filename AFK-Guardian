local function buildExportText()
    local res = AisbergGuardian.scanResult or AisbergGuardian.scanForAisbergHelpers()
    local lines = {}

    table.insert(lines, "=== Aisberg Guardian Scan Export ===")
    table.insert(lines, ("Platform: %s"):format(environment.isMobile and "Mobile" or "PC"))
    table.insert(lines, ("Executor: %s"):format(environment.executor))
    table.insert(lines, ("VirtualUser: %s"):format(environment.hasVirtualUser and "Available" or "Unavailable"))
    table.insert(lines, ("Camera: %s"):format(environment.hasCamera and "Available" or "Unavailable"))
    table.insert(lines, "--------------------------------")

    local count = 0

    if res.instances and #res.instances > 0 then
        table.insert(lines, "")
        table.insert(lines, "[Instances]")
        for _, info in ipairs(res.instances) do
            count += 1
            local matchStr = ""
            for i, m in ipairs(info.matches) do
                matchStr ..= (i > 1 and ", " or "") .. (m.field .. "='" .. m.match .. "'")
            end
            table.insert(lines, string.format(
                "  [%d] %s (%s) %s",
                count, info.path, info.class, matchStr
            ))
        end
    end

    if res.globals and #res.globals > 0 then
        table.insert(lines, "")
        table.insert(lines, "[Globals]")
        for _, info in ipairs(res.globals) do
            count += 1
            table.insert(lines, string.format(
                "  [%d] %s.%s type=%s match='%s'",
                count, info.source, info.key, info.valueType, info.match
            ))
        end
    end

    if count == 0 then
        table.insert(lines, "")
        table.insert(lines, "No suspicious scripts found.")
    else
        table.insert(lines, "")
        table.insert(lines, ("Total: %d potential script(s)."):format(count))
    end

    return table.concat(lines, "\n")
end

local function runScanAndLog()
    -- чистим лог, но не удаляем layout
    for _, child in ipairs(scrolling:GetChildren()) do
        if child ~= logLayout then
            child:Destroy()
        end
    end

    appendLogLine(">> scanning for afk / rejoin / guardian scripts...", Color3.fromRGB(0, 255, 120))

    local res = AisbergGuardian.scanForAisbergHelpers()
    local count = 0

    if res.instances and #res.instances > 0 then
        appendLogLine(">> instances:", Color3.fromRGB(0, 200, 255))
        for _, info in ipairs(res.instances) do
            count += 1
            local matchStr = ""
            for i, m in ipairs(info.matches) do
                matchStr ..= (i > 1 and ", " or "") .. (m.field .. "='" .. m.match .. "'")
            end
            appendLogLine(
                string.format("  [%d] %s (%s)  %s",
                    count, info.path, info.class, matchStr),
                Color3.fromRGB(170, 255, 170)
            )
        end
    end

    if res.globals and #res.globals > 0 then
        appendLogLine(">> globals:", Color3.fromRGB(0, 200, 255))
        for _, info in ipairs(res.globals) do
            count += 1
            appendLogLine(
                string.format("  [%d] %s.%s  match='%s' (%s)",
                    count, info.source, info.key, info.match, info.valueType),
                Color3.fromRGB(200, 220, 170)
            )
        end
    end

    if count == 0 then
        appendLogLine(">> nothing suspicious found.", Color3.fromRGB(140, 200, 255))
    else
        appendLogLine(">> total: " .. tostring(count) .. " potential script(s).", Color3.fromRGB(255, 210, 80))
    end

    updateExternalLabel()
end

local function exportScan()
    local txt = buildExportText()
    local exportedClipboard, exportedFile = false, false

    pcall(function()
        if setclipboard then
            setclipboard(txt)
            exportedClipboard = true
        elseif toclipboard then
            toclipboard(txt)
            exportedClipboard = true
        end
    end)

    pcall(function()
        if writefile then
            local fname = "AisbergGuardian_Scan_" .. os.date("%Y-%m-%d_%H-%M-%S") .. ".txt"
            writefile(fname, txt)
            exportedFile = true
        end
    end)

    if exportedClipboard or exportedFile then
        appendLogLine(">> export completed:", Color3.fromRGB(0, 255, 120))
        if exportedClipboard then
            appendLogLine("   - copied to clipboard", Color3.fromRGB(170, 255, 170))
        end
        if exportedFile then
            appendLogLine("   - saved to exploit workspace", Color3.fromRGB(170, 255, 170))
        end
    else
        appendLogLine(">> export failed: no setclipboard/writefile in this executor", Color3.fromRGB(255, 120, 120))
    end
end

