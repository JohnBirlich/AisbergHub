local suspiciousKeywords = {
    -- AFK / Anti-AFK
    "afk", "anti afk", "antiafk", "anti-afk", "noafk", "no afk",
    "stayonline", "stay online", "stay-afk",

    -- rejoin / auto rejoin
    "rejoin", "auto rejoin", "auto-rejoin", "autorejoin",
    "antirejoin", "anti rejoin", "autoreconnect", "auto reconnect",
    "reconnect",

    -- generic guardian / protect
    "afkguard", "afk guardian", "aisberg guardian", "guard afk",
}

-- безопасная проверка строки
local function containsKeyword(str)
    if not str or type(str) ~= "string" then return false end
    local s = string.lower(str)
    for _, kw in ipairs(suspiciousKeywords) do
        if string.find(s, kw, 1, true) then
            return true, kw
        end
    end
    return false
end

local function isSystemPath(fullName)
    if not fullName then return false end
    fullName = string.lower(fullName)
    if fullName:find("corepackages",   1, true) then return true end
    if fullName:find("robloxgui",      1, true) then return true end
    if fullName:find("voicechatcore",  1, true) then return true end
    if fullName:find("experiencechat", 1, true) then return true end
    return false
end

-- проверяем Name и Source
local function checkInstanceForKeywords(inst)
    local hits = {}

    -- имя
    local okName, kwName = pcall(function()
        local has, kw = containsKeyword(inst.Name)
        if has then return kw end
    end)
    if okName and kwName then
        table.insert(hits, { field = "Name", match = kwName })
    end

    -- Source (если доступен)
    if inst:IsA("LocalScript") or inst:IsA("ModuleScript") or inst:IsA("Script") then
        local okSrc, kwSrc = pcall(function()
            local src = inst.Source
            local has, kw = containsKeyword(src)
            if has then return kw end
        end)
        if okSrc and kwSrc then
            table.insert(hits, { field = "Source", match = kwSrc })
        end
    end

    return hits
end

local function scanInstances()
    local results = {}
    local roots = {
        workspace,
        StarterGui,
        ReplicatedFirst,
        LocalPlayer:FindFirstChild("PlayerGui"),
        CoreGui,
    }

    local maxFound = 100

    for _, root in ipairs(roots) do
        if root then
            for _, inst in ipairs(root:GetDescendants()) do
                if #results >= maxFound then
                    return results
                end

                if inst:IsA("LocalScript") or inst:IsA("ModuleScript")
                or inst:IsA("Script") or inst:IsA("ScreenGui") or inst:IsA("Folder") then

                    local fullName = inst:GetFullName()
                    if not isSystemPath(fullName) then
                        local hits = checkInstanceForKeywords(inst)
                        if #hits > 0 then
                            table.insert(results, {
                                instance = inst,
                                name     = inst.Name,
                                class    = inst.ClassName,
                                path     = fullName,
                                matches  = hits,
                            })
                        end
                    end
                end
            end
        end
    end

    return results
end

local function scanGlobals(tbl, sourceName)
    local res = {}
    if typeof(tbl) ~= "table" then return res end

    for k, v in pairs(tbl) do
        if typeof(k) == "string" then
            local ok, hit = containsKeyword(k)
            if ok then
                table.insert(res, {
                    key       = k,
                    valueType = typeof(v),
                    source    = sourceName,
                    match     = hit
                })
            end
        end
    end

    return res
end

function AisbergGuardian.scanForAisbergHelpers()
    local foundInstances = scanInstances()

    local okG,   globalTable = pcall(function() return _G end)
    local okGenv,genvTable   = pcall(function()
        if getgenv then
            return getgenv()
        end
    end)

    local foundGlobals = {}
    if okG and globalTable then
        for _, info in ipairs(scanGlobals(globalTable, "_G")) do
            table.insert(foundGlobals, info)
        end
    end
    if okGenv and genvTable and genvTable ~= _G then
        for _, info in ipairs(scanGlobals(genvTable, "getgenv")) do
            table.insert(foundGlobals, info)
        end
    end

    AisbergGuardian.scanResult = {
        instances = foundInstances,
        globals   = foundGlobals
    }

    return AisbergGuardian.scanResult
end

function AisbergGuardian.hasExternalAntiAisberg()
    local res = AisbergGuardian.scanResult or AisbergGuardian.scanForAisbergHelpers()

    local count = 0
    if res.instances then
        count = count + #res.instances
    end
    if res.globals then
        count = count + #res.globals
    end

    return count > 0, count
end

local function shouldEnableOurAntiAisberg()
    if not AisbergGuardian.ignoreIfOtherFound then
        return true
    end

    local found, count = AisbergGuardian.hasExternalAntiAisberg()
    if found then
        warn("[Aisberg Guardian] External anti-Aisberg/auto-rejoin scripts detected:", count)
        return false
    end

    return true
end

