local function cameraNudge()
    if not environment.hasCamera then return end

    local camera = workspace.CurrentCamera
    if not camera then return end

    local original = camera.CFrame
    local yaw   = math.rad(randRange(-1.5, 1.5))
    local pitch = math.rad(randRange(-0.8, 0.8))
    local target = original * CFrame.Angles(pitch, yaw, 0)

    local ok = pcall(function()
        local tween = TweenService:Create(camera,
            TweenInfo.new(randRange(0.15, 0.3), Enum.EasingStyle.Sine),
            {CFrame = target}
        )
        tween:Play()
        tween.Completed:Wait()
        TweenService:Create(camera,
            TweenInfo.new(randRange(0.15, 0.3), Enum.EasingStyle.Sine),
            {CFrame = original}
        ):Play()
    end)

    if not ok then
        camera.CFrame = camera.CFrame:Lerp(target, 0.5)
        task.wait(0.2)
        camera.CFrame = camera.CFrame:Lerp(original, 0.5)
    end
end

local function virtualAction()
    if not environment.hasVirtualUser then return end

    local count = math.random(1, 2)
    for _ = 1, count do
        if not AisbergGuardian.enabled then break end

        local ok = pcall(function()
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new(0, 0))
        end)

        if not ok then
            pcall(function()
                VirtualUser:Button2Down(Vector2.new(0, 0), workspace)
                task.wait(0.05)
                VirtualUser:Button2Up(Vector2.new(0, 0), workspace)
            end)
        end

        task.wait(randRange(0.4, 1.2))
    end
end

local function performAction()
    if not AisbergGuardian.enabled then return end

    local modes = {}
    if environment.hasCamera      then table.insert(modes, cameraNudge)   end
    if environment.hasVirtualUser then table.insert(modes, virtualAction) end
    if #modes == 0 then return end

    local roll = math.random(1, 10)
    if roll <= 5 and environment.hasCamera then
        cameraNudge()
    elseif roll <= 8 and environment.hasVirtualUser then
        virtualAction()
    else
        if environment.hasCamera then
            cameraNudge()
            task.wait(randRange(0.5, 1))
        end
        if environment.hasVirtualUser then
            virtualAction()
        end
    end
end

