--------------------------------------------------
-- Drag
--------------------------------------------------

do
    local dragging = false
    local dragInput, dragStart, startPos

    local function update(input)
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end

    header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    header.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            update(input)
        end
    end)
end

--------------------------------------------------
-- Collapse / expand
--------------------------------------------------

local expandedSize  = UDim2.new(0, 260, 0, 70)
local collapsedSize = UDim2.new(0, 260, 0, 30)
local isCollapsed   = false

local function setCollapsed(state)
    isCollapsed = state
    local info = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    local targetSize = state and collapsedSize or expandedSize
    TweenService:Create(mainFrame, info, { Size = targetSize }):Play()

    statusFrame.Visible = not state
end

--------------------------------------------------
-- Привязка визуала к флагу
--------------------------------------------------

local function updateToggleVisual()
    if checkerEnabled then
        toggleButton.Text = "ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(35, 120, 55)
        statusText.Text = "Active protection"
        statusText.TextColor3 = Color3.fromRGB(180, 220, 180)
        dot.BackgroundColor3 = Color3.fromRGB(40, 200, 80)
    else
        toggleButton.Text = "OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(120, 45, 45)
        statusText.Text = "Protection disabled"
        statusText.TextColor3 = Color3.fromRGB(220, 160, 140)
        dot.BackgroundColor3 = Color3.fromRGB(200, 80, 60)
    end
end

toggleButton.Activated:Connect(function()
    checkerEnabled = not checkerEnabled
    updateToggleVisual()
    print("[Inv Guardian] Checker is now " .. (checkerEnabled and "ENABLED" or "DISABLED") .. " at " .. getTimeString())
end)

updateToggleVisual()

--------------------------------------------------
-- Основной цикл проверки
--------------------------------------------------

local function startChecker()
    while true do
        waitForCharacter()

        if not checkerEnabled then
            task.wait(1)
            continue
        end

        local items = getInventoryNames()
        local timeStr = getTimeString()

        if #items > 0 then
            local list = table.concat(items, ", ")
            print("[Inv Guardian] Items: " .. list .. " | All good | " .. timeStr)
            task.wait(CHECK_INTERVAL)
        else
            print("[Inv Guardian] No items, resetting character | " .. timeStr)
            resetCharacter()
            waitForCharacter()

            local afterItems = getInventoryNames()
            local afterTime  = getTimeString()

            if #afterItems > 0 then
                local list = table.concat(afterItems, ", ")
                print("[Inv Guardian] After reset: Items: " .. list .. " | All good | " .. afterTime)
                task.wait(CHECK_INTERVAL)
            else
                print("[Inv Guardian] After reset: still no items | " .. afterTime)
                task.wait(5)
            end
        end
    end
end

waitForCharacter()
task.spawn(startChecker)
