-- === Auto Playtime Rewards по состоянию Claim/Claimed ===

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function startAutoClickPlaytimeRewards()
    local ok, err = pcall(function()
        local pg = LocalPlayer:WaitForChild("PlayerGui")
        local mainUi = pg:WaitForChild("Main_User_Interface")
        local rewardsRoot = mainUi:WaitForChild("Rewards")
        local playtime = rewardsRoot:WaitForChild("PlaytimeRewards")
        local rewardsFolder = playtime:FindFirstChild("Rewards") or playtime

        local rewardButtons = {}

        for _, tierFrame in ipairs(rewardsFolder:GetChildren()) do
            if tierFrame:IsA("Frame") then
                local btn = tierFrame:FindFirstChild("Button")
                if btn and btn:IsA("GuiButton") then
                    local txtLabel = btn:FindFirstChild("Frame") and btn.Frame:FindFirstChild("TextLabel")
                    local claimedGui = btn:FindFirstChild("Claimed")
                    if txtLabel and claimedGui then
                        table.insert(rewardButtons, {
                            Tier    = tierFrame.Name,
                            Button  = btn,
                            Label   = txtLabel,
                            Claimed = claimedGui
                        })
                    end
                end
            end
        end

        if #rewardButtons == 0 then
            warn("[AisbergHub][Playtime] Auto-claim: no buttons found")
            return
        end

        print("[AisbergHub][Playtime] Auto-claim started")

        task.spawn(function()
            while task.wait(2) do
                for _, info in ipairs(rewardButtons) do
                    local btn     = info.Button
                    local lbl     = info.Label
                    local claimed = info.Claimed

                    if not (btn and btn.Parent and btn.Parent.Visible and btn.Visible and btn.Active ~= false) then
                        continue
                    end

                    local text = lbl.Text
                    local claimedVisible = claimed.Visible

                    -- готово к получению: Claim + Claimed.Visible=false
                    if text == "Claim" and not claimedVisible then
                        print("[AisbergHub][Playtime] Auto-claiming", info.Tier)
                        pcall(function()
                            btn:Activate()
                        end)
                    end
                end
            end
        end)
    end)

    if not ok then
        warn("[AisbergHub][Playtime] Auto-claim init error:", err)
    end
end

-- один раз из твоего основного скрипта:
startAutoClickPlaytimeRewards()
