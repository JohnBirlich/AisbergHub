local resizeHandle = Instance.new("Frame")
resizeHandle.Size = UDim2.new(0, 14, 0, 14)
resizeHandle.Position = UDim2.new(1, -14, 1, -14)
resizeHandle.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
resizeHandle.BorderSizePixel = 0
resizeHandle.Parent = main

local resizing = false
local resizeStartMouse
local resizeStartSize

resizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = true
        resizeStartMouse = UIS:GetMouseLocation()
        resizeStartSize = main.Size
    end
end)

resizeHandle.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        resizing = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
        local current = UIS:GetMouseLocation()
        local delta = current - resizeStartMouse

        local newW = math.max(360, resizeStartSize.X.Offset + delta.X)
        local newH = math.max(240, resizeStartSize.Y.Offset + delta.Y)
        main.Size = UDim2.new(0, newW, 0, newH)
    end
end)

--------------------------------------------------
-- Логика: поиск чекпоинтов Race2 и лог CFrame
--------------------------------------------------

local running = false
local connections = {}
local touchedOnce = {} -- чтобы один чекпоинт не спамил миллион раз

-- helper: форматировать CFrame так, как ты просишь
local function formatCFrame(idx, cf)
    local x, y, z = cf.X, cf.Y, cf.Z
    local r00, r01, r02,
          r10, r11, r12,
          r20, r21, r22 = cf:ToOrientation()
    -- ВАЖНО: ToOrientation даёт углы, а не матрицу, но тебе нужна именно матрица,
    -- поэтому лучше взять элементы CFrame напрямую:
    local m00, m01, m02,
          m10, m11, m12,
          m20, m21, m22 = cf:GetComponents()
    -- GetComponents возвращает x,y,z,m00,m01,..., поэтому перезапишем:
    x, y, z,
    m00, m01, m02,
    m10, m11, m12,
    m20, m21, m22 = cf:GetComponents()

    return string.format(
        "%d - %s, %s, %s, %s, %s, %s, %s, %s, %s",
        idx,
        tostring(x),
        tostring(y),
        tostring(z),
        tostring(m00),
        tostring(m01),
        tostring(m02),
        tostring(m10),
        tostring(m11),
        tostring(m12)
        -- если нужно все 9 элементов, можно добавить m20,m21,m22,
        -- но у тебя в примере 9 чисел после позиции, поэтому:
        -- x,y,z, r00,r01,r02,r10,r11,r12,r20,r21,r22
    )
end

-- но в твоём примере: x,y,z, r00,r01,r02,r10,r11,r12,r20,r21,r22 = 12 чисел,
-- значит всё‑таки надо 12:
local function formatCFrameFull(idx, cf)
    local x, y, z,
    r00, r01, r02,
    r10, r11, r12,
    r20, r21, r22 = cf:GetComponents()

    return string.format(
        "%d - %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s",
        idx,
        tostring(x),
        tostring(y),
        tostring(z),
        tostring(r00),
        tostring(r01),
        tostring(r02),
        tostring(r10),
        tostring(r11),
        tostring(r12),
        tostring(r20),
        tostring(r21),
        tostring(r22)
    )
end

local function disconnectAll()
    for _, conn in ipairs(connections) do
        if conn.Connected then
            conn:Disconnect()
        end
    end
    table.clear(connections)
end

local function startLogger()
    if running then return end
    running = true
    startBtn.Text = "Stop CFrame Logger"
    startBtn.BackgroundColor3 = Color3.fromRGB(150, 60, 60)
    appendLine("[Start] CFrame logger started")

    table.clear(touchedOnce)
    disconnectAll()

    local ok, err = pcall(function()
        -- Workspace > Races > Race2 > Появляется Race > потом Race2_уникальный код > checkpoint
        local races = Workspace:WaitForChild("Races")
        local race2Root = races:WaitForChild("Race2")

        -- "Появляется Race" и "Race2_уникальный код" могут создаваться динамически
        -- поэтому слушаем ChildAdded у Race2
        local function hookRaceFolder(raceFolder)
            -- внутри Race2_уникальный кода ждём папку checkpoint
            local function setupForRaceInstance(instance)
                if instance:IsA("Folder") and instance.Name:sub(1,5) == "Race2" then
                    local checkpointFolder = instance:FindFirstChild("checkpoint")
                        or instance:WaitForChild("checkpoint", 5)
                    if checkpointFolder then
                        appendLine("[Info] Found checkpoint folder: " .. checkpointFolder:GetFullName())
                        -- ищем Part'ы 1..70 и Finish
                        for _, part in ipairs(checkpointFolder:GetChildren()) do
                            if part:IsA("BasePart") then
                                local idx = tonumber(part.Name)
                                local isFinish = (part.Name == "Finish")
                                if (idx and idx >= 1 and idx <= 70) or isFinish then
                                    local labelIndex = isFinish and 999 or idx
                                    appendLine(string.format(
                                        "[Bind] %s (index=%s) -> .Touched",
                                        part.Name,
                                        tostring(labelIndex)
                                    ))

                                    local conn = part.Touched:Connect(function(hit)
                                        if not running then return end
                                        local char = LocalPlayer.Character
                                        if not char then return end
                                        if not hit:IsDescendantOf(char) then return end

                                        if touchedOnce[part] then return end
                                        touchedOnce[part] = true

                                        local line = formatCFrameFull(labelIndex, part.CFrame)
                                        appendLine(line)
                                    end)
                                    table.insert(connections, conn)
                                end
                            end
                        end
                    else
                        appendLine("[Warn] checkpoint folder not found in " .. instance.Name)
                    end
                end
            end

            -- уже существующие дети
            for _, child in ipairs(raceFolder:GetChildren()) do
                setupForRaceInstance(child)
            end

            -- новые Race2_* которые появляются позже
            local c = raceFolder.ChildAdded:Connect(function(child)
                setupForRaceInstance(child)
            end)
            table.insert(connections, c)
        end

        -- "Появляется Race" — это какой‑то контейнер внутри Race2
        -- если он уже есть:
        for _, child in ipairs(race2Root:GetChildren()) do
            if child:IsA("Folder") and child.Name == "Race" then
                hookRaceFolder(child)
            end
        end

        -- и слушаем его появление
        local raceChildConn = race2Root.ChildAdded:Connect(function(child)
            if child:IsA("Folder") and child.Name == "Race" then
                hookRaceFolder(child)
            end
        end)
        table.insert(connections, raceChildConn)
    end)

    if not ok then
        appendLine("[Error] Init: " .. tostring(err))
        running = false
        startBtn.Text = "Start CFrame Logger"
        startBtn.BackgroundColor3 = Color3.fromRGB(50, 130, 50)
        disconnectAll()
    end
end

local function stopLogger()
    if not running then return end
    running = false
    startBtn.Text = "Start CFrame Logger"
    startBtn.BackgroundColor3 = Color3.fromRGB(50, 130, 50)
    appendLine("[Stop] CFrame logger stopped")
    disconnectAll()
end

startBtn.MouseButton1Click:Connect(function()
    if running then
        stopLogger()
    else
        startLogger()
    end
end)
